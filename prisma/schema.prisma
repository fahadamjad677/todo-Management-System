// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}


// User Table
model User {
  id String  @id @default(uuid())
  email String @unique
  name String
  password String
  roleId   String 

  departments UserDepartment[]
  role Role @relation(fields: [roleId],references: [id])


  
  reportedTasks Task[] @relation("ReportedTasks")
  assignedTasks Task[] @relation("AssignedTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}


//Department Table
model Department{
  id String  @id @default(uuid())
  name String @unique

  users UserDepartment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//User Department Table (many-to-many)
model UserDepartment{
  userId String 
  departmentId String 

  user User  @relation(fields: [userId], references: [id])
  department Department @relation(fields: [departmentId],references: [id])

  @@id([userId,departmentId]) //Composite primary key
}



//Role Table 
model Role{
  id String  @id @default(uuid())
  name String @unique


  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//Enums
enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  DONE
}


//Tasks Table
model Task{
  id   String   @id @default(uuid())
  name String
  priority  Priority   @default(MEDIUM)
  Description String
  time      DateTime
  status    Status    @default(TODO)

  //reported to:userid , assignedTo:userid both are foreign keys
  reportedToId  String @unique
  assignedToId  String @unique



//Relations
 reportedTo User @relation("ReportedTasks", fields: [reportedToId], references: [id])
  assignedTo User @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}