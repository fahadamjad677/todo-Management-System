// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}


// User Table
model User {
  id String  @id @default(uuid())
  email String @unique
  name String
  password String
  roleId   String 
  refreshToken String?
  departments UserDepartment[]
  role Role @relation(fields: [roleId],references: [id])


  
  reportedTasks Task[] @relation("ReportedTasks")
  assignedTasks Task[] @relation("AssignedTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  tasks Task[] @relation("CreatedTasks")

  comments Comment[]
}


//Department Table
model Department{
  id String  @id @default(uuid())
  name String @unique

  users UserDepartment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//User Department Table (many-to-many)
model UserDepartment{
  userId String 
  departmentId String 

  user User  @relation(fields: [userId], references: [id],onDelete: Cascade)
  department Department @relation(fields: [departmentId],references: [id],onDelete: Cascade)

  @@id([userId,departmentId]) //Composite primary key
}



//Role Table 
model Role{
  id String  @id @default(uuid())
  name String @unique


  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//Enums
enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum Status {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}


//Tasks Table
model Task{
  id   String   @id @default(uuid())
  name String
  priority  Priority   @default(MEDIUM)
  Description String
  time      DateTime
  status    Status    @default(TODO)

  //reported to:userid , assignedTo:userid both are foreign keys
  reportedToId  String 
  assignedToId  String 
  createdbyId   String

  // Scores
  assignedScore Int    // set at creation
  obtainedScore Int?     // set after completion

//Relations
 reportedTo User @relation("ReportedTasks", fields: [reportedToId], references: [id])
  assignedTo User @relation("AssignedTasks", fields: [assignedToId], references: [id])
   createdById User @relation("CreatedTasks", fields: [createdbyId], references:[id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments Comment[]
}


//Comment Table
model Comment {
  id        String   @id @default(uuid())
  content   String

  taskId    String
  userId    String

  task      Task     @relation(fields: [taskId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  deletedAt DateTime?
}